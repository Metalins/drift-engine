# Server config
METALINS_ENV=development
METALINS_DB_URL=sqlite:///./metalins-dev.sqlite
METALINS_HOST=0.0.0.0
METALINS_PORT=8000

# κ-Proof signing
METALINS_PRIVATE_KEY_PATH=./keys/private_key.pem
METALINS_PUBLIC_KEY_PATH=./keys/public_key.pem
METALINS_KEY_ID=metalins-key-2026-1
METALINS_PROOF_TTL_SECONDS=3600

# API
METALINS_API_BASE_URL=http://localhost:8000
METALINS_PUBLIC_BASE_URL=http://localhost:8000

# Logging
METALINS_LOG_LEVEL=INFO

# --- Local auth (gh-117 / gh-118, self-hosted) -----------------------------
# Drift Engine owns its own login — no external identity provider required.
#
# First-run admin: created automatically on startup if no admin exists.
METALINS_ADMIN_EMAIL=admin@localhost
METALINS_ADMIN_PASSWORD=changeme
#
# Session JWT signing secret. Optional — when unset it is derived from the
# RS256 signing key (persisted in the keys volume), so docker-compose works
# with zero config. Set it to rotate all sessions or to share auth across
# replicas that don't share the signing key.
# METALINS_AUTH_JWT_SECRET=
# METALINS_AUTH_JWT_TTL_SECONDS=86400

# --- Supabase Auth (LEGACY — optional) -------------------------------------
# Only needed for José's pre-pivot instance during the dashboard cutover.
# A self-hosted install leaves these UNSET and uses local auth above.
# METALINS_SUPABASE_URL=https://your-project.supabase.co
# METALINS_SUPABASE_PROJECT_REF=your-project
# METALINS_SUPABASE_JWT_SECRET=your-hs256-jwt-secret
