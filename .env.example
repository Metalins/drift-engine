# Server config
METALINS_ENV=development
METALINS_DB_URL=sqlite:///./metalins-dev.sqlite
METALINS_HOST=0.0.0.0
METALINS_PORT=8000

# κ-Proof signing
METALINS_PRIVATE_KEY_PATH=./keys/private_key.pem
METALINS_PUBLIC_KEY_PATH=./keys/public_key.pem
METALINS_KEY_ID=metalins-key-2026-1
METALINS_PROOF_TTL_SECONDS=3600

# API
METALINS_API_BASE_URL=http://localhost:8000
METALINS_PUBLIC_BASE_URL=http://localhost:8000

# Logging
METALINS_LOG_LEVEL=INFO

# Local auth (self-hosted, gh-117/gh-119)
# Drift Engine owns its own login — no external identity provider. On first
# boot the server creates an admin account (defaults: admin@localhost /
# changeme) and, when the default password is used, requires a change on first
# login. Sign in to the dashboard and update it from Settings → Password.
# All optional — defaults work out of the box; the session JWT secret is
# derived from the signing key when left unset.
# METALINS_ADMIN_EMAIL=admin@localhost
# METALINS_ADMIN_PASSWORD=changeme
# METALINS_AUTH_JWT_SECRET=

# Dashboard (Next.js)
# Host port the dashboard is exposed on.
DASHBOARD_PORT=3000
# Base URL of the API server as seen from the dashboard container. The default
# (the `server` docker-compose service) is correct for the bundled stack.
DRIFT_ENGINE_API_URL=http://server:8000
